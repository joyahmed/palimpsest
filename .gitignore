node_modules/
.env
.env.local
dist/
*.tsbuildinfo

# Deploy artifacts: compiled JS, the staged Function Compute package, and the
# vendored Node runtime that ships inside it. All rebuilt by `pnpm package:fc`.
build/
deploy/
runtime/

# TLS material for the custom domain. The private key must never enter the repo -
# re-issue with `pnpm cert` instead of ever committing this.
certs/

# NOTE: .cache/llm is deliberately NOT ignored - the model-call cache is committed
# so anyone can replay the benchmark and reproduce our numbers without a key
# and without spending anything. That reproducibility is part of the submission.
#
# .cache/node IS ignored - it's a ~30 MB Node tarball, re-downloadable and
# checksum-verified on every package build. Nothing reproducible depends on it.
.cache/node/

# Internal working docs - strategy and delivery notes. Local only, never published.
PLAN.md
VIDEO-SCRIPT.md

palimpsest.db
bench-*.db
dist/

# Submission drafts - the Devpost story, the X thread, the coaching notes on how to land
# them. Same reason PLAN.md and VIDEO-SCRIPT.md are ignored: strategy and delivery notes,
# local only, never published. A judge should read the repo, not the pitch about the repo.
DEVPOST.md
X-THREAD.md
X-POSTS.txt

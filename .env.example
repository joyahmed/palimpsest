# Qwen Cloud - OpenAI-compatible endpoint.
# Get a key: https://home.qwencloud.com/api-keys
#
# IMPORTANT: Qwen Cloud keys live on the INTERNATIONAL (Singapore) endpoint.
# Pointing them at the mainland-China endpoint (dashscope.aliyuncs.com) returns
# HTTP 401 invalid_api_key even though the key is perfectly valid. This is the
# single most common way to lose an hour here.
DASHSCOPE_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Memory store. One SQLite file. No daemon, no container, no port.
PALIMPSEST_DB=./palimpsest.db

# Disk cache for model calls. Every unique (model, prompt) is paid for ONCE.
# Load-bearing, not an optimisation: it decouples us from the free tier's rate
# limiter and makes the benchmark reproducible by anyone, without a key.
PALIMPSEST_CACHE_DIR=.cache/llm

# Set to 1 to fail loudly on a cache miss instead of calling the API.
# Used for benchmark replay so a rerun can never silently spend money.
PALIMPSEST_CACHE_ONLY=0

# ---------------------------------------------------------------- deployment only
# Needed ONLY to deploy to Alibaba Cloud Function Compute (`pnpm deploy`). Nothing in
# the library, the benchmark or the MCP server touches these - you can run, replay and
# audit this entire project without an Alibaba account.
#
# A RAM user with AliyunFCFullAccess + AliyunOSSFullAccess is enough. OSS is required
# because the code package (which carries its own Node 24 - see Dockerfile-less
# src/scripts/package-fc.ts) exceeds the 100 MB direct-upload limit and is staged
# through OSS.
ALIBABA_CLOUD_ACCESS_KEY_ID=...
ALIBABA_CLOUD_ACCESS_KEY_SECRET=...